rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.uid == "Q2yXz2O4zRRPfQOQBykjxXpVwBE3";
    }

    match /events/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /biome_regions/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /biome_reports/{id} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.userUid == request.auth.uid;
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.userUid == request.auth.uid);
    }

    match /users/{uid} {
      allow read, write: if isSignedIn()
        && (request.auth.uid == uid || isAdmin());
    }
  }
}
